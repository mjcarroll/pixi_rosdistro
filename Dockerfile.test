FROM ubuntu:22.04

# Avoid interactive prompts during installations
ENV DEBIAN_FRONTEND=noninteractive

# Install minimal system dependencies required by Pixi and some vendor packages
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Install Pixi
RUN curl -fsSL https://pixi.sh/install.sh | bash
ENV PATH="/root/.pixi/bin:$PATH"

# Set up workspace (but don't mount host .pixi)
WORKDIR /workspace

# Copy only requirements to cache environment
COPY pixi.toml pixi.lock ./

# Pre-install environment for Linux
RUN pixi install

# Copy the rest of the project
# Note: we will mount the source during runtime for iteration
CMD ["/bin/bash"]
